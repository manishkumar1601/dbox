# Generated by PHPBox — do not edit by hand.
# Edit ../phpbox.yml and run `phpbox start` to regenerate.
name: phpbox-{{ name }}

services:
  php:
    build:
      context: ./php
      dockerfile: Dockerfile
    container_name: phpbox-{{ name }}-php
    restart: unless-stopped
    working_dir: /var/www/html
    volumes:
      - ../:/var/www/html
    {% if server == 'apache' and ssl.enabled %}
      - ./certs:/etc/phpbox/certs:ro
      - ./apache/ssl.conf:/etc/apache2/sites-enabled/phpbox-ssl.conf:ro
    {% endif %}
    {% if server == 'apache' %}
    ports:
      - "{{ ports.http }}:80"
      {% if ssl.enabled %}
      - "{{ ports.https }}:443"
      {% endif %}
    {% endif %}
    {% if app_env %}
    environment:
      {% for key, value in app_env.items() %}
      "{{ key }}": "{{ value }}"
      {% endfor %}
    {% endif %}
    {% if needs_db %}
    depends_on:
      db:
        condition: service_healthy
    {% endif %}
    networks:
      - phpbox

  {% if separate_web %}
  web:
    image: {{ web_image }}
    container_name: phpbox-{{ name }}-web
    restart: unless-stopped
    depends_on:
      - php
    ports:
      - "{{ ports.http }}:80"
      {% if ssl.enabled %}
      - "{{ ports.https }}:443"
      {% endif %}
    volumes:
      - ../:/var/www/html
      {% if server == 'caddy' %}
      - ./caddy/Caddyfile:/etc/caddy/Caddyfile:ro
      {% elif server == 'litespeed' %}
      - ./litespeed/httpd_config.conf:/usr/local/lsws/conf/httpd_config.conf:ro
      - ./litespeed/vhconf.conf:/usr/local/lsws/conf/vhosts/Default/vhconf.conf:ro
      {% else %}
      - ./nginx/default.conf:/etc/nginx/conf.d/default.conf:ro
      {% endif %}
      {% if ssl.enabled %}
      - ./certs:/etc/phpbox/certs:ro
      {% endif %}
    networks:
      - phpbox
  {% endif %}

  {% if needs_db %}
  db:
    image: {{ db.image }}
    container_name: phpbox-{{ name }}-db
    restart: unless-stopped
    environment:
      {% for key, value in db.env.items() %}
      {{ key }}: "{{ value }}"
      {% endfor %}
    volumes:
      - ./data/{{ db_engine }}:{{ db.data_dir }}
    ports:
      - "{{ ports.database }}:{{ db.container_port }}"
    healthcheck:
      test: {{ db.healthcheck | tojson }}
      interval: 5s
      timeout: 5s
      retries: 30
      start_period: 30s
    networks:
      - phpbox
  {% endif %}

  {% if services.redis %}
  redis:
    image: redis:7-alpine
    container_name: phpbox-{{ name }}-redis
    restart: unless-stopped
    ports:
      - "{{ ports.redis }}:6379"
    networks:
      - phpbox
  {% endif %}

  {% if services.mailpit %}
  mailpit:
    image: axllent/mailpit:latest
    container_name: phpbox-{{ name }}-mailpit
    restart: unless-stopped
    ports:
      - "{{ ports.mailpit }}:8025"
    networks:
      - phpbox
  {% endif %}

  {% if services.phpmyadmin and needs_db %}
  phpmyadmin:
    image: phpmyadmin:latest
    container_name: phpbox-{{ name }}-phpmyadmin
    restart: unless-stopped
    environment:
      PMA_HOST: db
      PMA_PORT: "{{ db.container_port }}"
    ports:
      - "{{ ports.phpmyadmin }}:80"
    depends_on:
      - db
    networks:
      - phpbox
  {% endif %}

  {% if services.meilisearch %}
  meilisearch:
    image: getmeili/meilisearch:latest
    container_name: phpbox-{{ name }}-meilisearch
    restart: unless-stopped
    ports:
      - "{{ ports.meilisearch }}:7700"
    networks:
      - phpbox
  {% endif %}

  {% if services.elasticsearch %}
  elasticsearch:
    image: docker.elastic.co/elasticsearch/elasticsearch:8.13.4
    container_name: phpbox-{{ name }}-elasticsearch
    restart: unless-stopped
    environment:
      discovery.type: single-node
      xpack.security.enabled: "false"
      ES_JAVA_OPTS: "-Xms512m -Xmx512m"
    ports:
      - "{{ ports.elasticsearch }}:9200"
    networks:
      - phpbox
  {% endif %}

networks:
  phpbox:
    driver: bridge
