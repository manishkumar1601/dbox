# Generated by PHPBox — do not edit by hand.
# Edit ../../phpbox.yml and run `phpbox start` to regenerate.
{% if server == 'apache' %}
FROM php:{{ php_version }}-apache
{% else %}
FROM php:{{ php_version }}-fpm
{% endif %}

# Base tooling (Composer/WP-CLI/scaffolding need these).
RUN apt-get update && apt-get install -y --no-install-recommends \
    git unzip curl ca-certificates \
 && rm -rf /var/lib/apt/lists/*

# Install PHP extensions with mlocati/install-php-extensions: it pulls
# prebuilt binaries where available and resolves system dependencies
# automatically — far faster than compiling each extension from source.
COPY --from=mlocati/php-extension-installer:latest /usr/bin/install-php-extensions /usr/local/bin/
{% if php_extensions %}
RUN install-php-extensions {{ php_extensions | join(' ') }}
{% endif %}

# Composer.
COPY --from=composer:{{ composer_version }} /usr/bin/composer /usr/bin/composer

{% if install_wp_cli %}
# WP-CLI for WordPress projects.
RUN curl -fsSL https://raw.githubusercontent.com/wp-cli/builds/gh-pages/phar/wp-cli.phar \
      -o /usr/local/bin/wp \
 && chmod +x /usr/local/bin/wp
{% endif %}

# PHP configuration overrides from phpbox.yml.
COPY php.ini /usr/local/etc/php/conf.d/zz-phpbox.ini

{% if server == 'apache' %}
# Apache (mod_php) document root + .htaccess support.
RUN a2enmod rewrite ssl
RUN sed -ri 's!DocumentRoot /var/www/html!DocumentRoot {{ apache_docroot }}!g' \
      /etc/apache2/sites-available/000-default.conf
RUN printf '<Directory {{ apache_docroot }}>\n    AllowOverride All\n    Require all granted\n</Directory>\n' \
      > /etc/apache2/conf-available/phpbox.conf \
 && a2enconf phpbox
# Run Apache as root so it can always write to bind-mounted project files
# (e.g. Laravel's storage/) regardless of how the host exposes file ownership.
# This is a local development environment, so running as root is acceptable.
ENV APACHE_RUN_USER=root
ENV APACHE_RUN_GROUP=root
{% else %}
# Run the PHP-FPM worker as root so it can always write to bind-mounted project
# files (e.g. Laravel's storage/, Symfony's var/) regardless of how the host
# exposes file ownership — Windows/macOS Docker bind mounts often ignore chmod.
# This is a local development environment, so running as root is acceptable.
# php-fpm rejects a root pool unless the master is started with -R.
RUN sed -ri 's/^user = www-data/user = root/; s/^group = www-data/group = root/' \
      /usr/local/etc/php-fpm.d/www.conf
CMD ["php-fpm", "--allow-to-run-as-root"]
{% endif %}

WORKDIR /var/www/html
