# Generated by PHPBox — connection details for the running stack.
# Use these values inside your app's own .env file.
{% if needs_db %}
DB_CONNECTION={{ 'pgsql' if db_engine == 'postgres' else 'mysql' }}
DB_HOST=db
DB_PORT={{ db.container_port }}
DB_DATABASE={{ cfg.database.name }}
DB_USERNAME={{ cfg.database.user }}
DB_PASSWORD={{ cfg.database.password }}
{% else %}
DB_CONNECTION=sqlite
{% endif %}
{% if services.redis %}
REDIS_HOST=redis
REDIS_PORT=6379
{% endif %}
{% if services.mailpit %}
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
{% endif %}
{% if services.meilisearch %}
MEILISEARCH_HOST=http://meilisearch:7700
{% endif %}
{% if services.elasticsearch %}
ELASTICSEARCH_HOST=http://elasticsearch:9200
{% endif %}
