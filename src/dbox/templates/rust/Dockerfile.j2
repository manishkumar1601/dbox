{# "stable" → `rust:bookworm` (Docker Hub's alias for the latest stable on
   bookworm); a pinned version like "1.83" → `rust:1.83-bookworm`. #}
FROM rust:{% if rust_version == "stable" %}bookworm{% else %}{{ rust_version }}-bookworm{% endif %}

RUN apt-get update && apt-get install -y --no-install-recommends \
      pkg-config libssl-dev curl ca-certificates \
 && rm -rf /var/lib/apt/lists/*

# Live-reload tool: rebuilds + restarts the app on file changes.
RUN cargo install cargo-watch --locked

WORKDIR /app
EXPOSE 8080
CMD ["cargo", "watch", "-x", "run"]
