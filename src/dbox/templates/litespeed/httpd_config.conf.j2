## Generated by DBox — do not edit by hand.
## Edit ../../dbox.yml and run `dbox start` to regenerate.
## OpenLiteSpeed proxies PHP to the separate php-fpm container over FastCGI.
serverName                DBox
user                      nobody
group                     nogroup
priority                  0
autoRestart               1
enableChroot              0
inMemBufSize              60M
swappingDir               /tmp/lshttpd/swap
autoFix503                1
gracefulRestartTimeout    300
mime                      conf/mime.properties
showVersionNumber         0
indexFiles                index.php, index.html

errorlog logs/error.log {
  logLevel                ERROR
  rollingSize             10M
}

accesslog logs/access.log {
  rollingSize             10M
  keepDays                7
}

extprocessor phpfpm {
  type                    fcgi
  address                 php:9000
  maxConns                35
  initTimeout             60
  retryTimeout            0
  respBuffer              0
  persistConn             1
  ## php-fpm runs in a separate container, so OLS must NOT launch it.
  ## `path` is required by the parser but unused when autoStart is off.
  autoStart               0
  path                    /usr/local/lsws/fcgi-bin/lsphp
}

scripthandler {
  add                     fcgi:phpfpm php
}

listener Default {
  address                 *:80
  secure                  0
  map                     Default *
}
{% if ssl.enabled %}

listener DefaultSSL {
  address                 *:443
  secure                  1
  keyFile                 /etc/dbox/certs/key.pem
  certFile                /etc/dbox/certs/cert.pem
  map                     Default *
}
{% endif %}

virtualhost Default {
  vhRoot                  /var/www/html
  configFile              conf/vhosts/Default/vhconf.conf
  allowSymbolLink         1
  enableScript            1
  restrained              0
}
